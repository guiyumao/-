SETUP_COMPLETE=true
LAST30DAYS_MEMORY_DIR=C:\Users\wdx\Documents\Last30Days
LAST30DAYS_STORE=1

# core
LAST30DAYS_REASONING_PROVIDER=auto
# LAST30DAYS_PLANNER_MODEL=
# LAST30DAYS_RERANK_MODEL=
# OPENAI_MODEL_PIN=
# XAI_MODEL_PIN=

# reasoning provider keys
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_GENAI_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=
# PARALLEL_API_KEY=

# web search backend
# BRAVE_API_KEY=replace_with_your_brave_key
# EXA_API_KEY=
# SERPER_API_KEY=

# enhanced social setup
# fill this to unlock tiktok / instagram / threads
# SCRAPECREATORS_API_KEY=replace_with_your_scrapecreators_key
# APIFY_API_TOKEN=
INCLUDE_SOURCES=tiktok,instagram,threads
EXCLUDE_SOURCES=

# x / twitter auth
# choose one path:
# 1) browser cookies
# AUTH_TOKEN=replace_with_your_x_auth_token
# CT0=replace_with_your_x_ct0
# 2) browser session auto-detect
# FROM_BROWSER=firefox
# 3) api key
# XAI_API_KEY=replace_with_your_xai_key
# LAST30DAYS_X_BACKEND=
# LAST30DAYS_X_MODEL=

# bluesky
# BSKY_HANDLE=your_handle.bsky.social
# BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# BSKY_SEARCH_HOST=api.bsky.app

# truth social
# TRUTHSOCIAL_TOKEN=

# xiaohongshu
# XIAOHONGSHU_API_BASE=http://host.docker.internal:18060

# runtime tuning
# LAST30DAYS_TRANSCRIPT_TIMEOUT=30
# LAST30DAYS_DEBUG=1
# LAST30DAYS_SKIP_PREFLIGHT=1
# LAST30DAYS_YOUTUBE_SSH_HOST=

# notes
# add pinterest only when you want pinterest results on purpose
# example:
# INCLUDE_SOURCES=tiktok,instagram,threads,pinterest
# comment enrichment is extra-cost and should be opt-in:
# INCLUDE_SOURCES=tiktok,instagram,threads,youtube_comments,tiktok_comments
