APP_NAME=lab_management_system
APP_TIMEZONE=Asia/Shanghai

BACKEND_BIND_ADDRESS=0.0.0.0
BACKEND_PORT=8080
BACKEND_PUBLIC_URL=https://api.example.com
SWAGGER_PATH=/swagger-ui.html

FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
FRONTEND_PUBLIC_URL=https://lab.example.com

VITE_FRONTEND_HOST=0.0.0.0
VITE_FRONTEND_PORT=5173
VITE_API_BASE_URL=https://api.example.com/api
VITE_AUTH_HEADER_PREFIX=Bearer

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lab_management_system
DB_USERNAME=root
DB_PASSWORD=请替换为安全密码

MYSQL_IMAGE=mysql:8.0.36
MYSQL_CONTAINER_NAME=lab-management-mysql
MYSQL_ROOT_PASSWORD=请替换为安全密码
MYSQL_HEALTHCHECK_HOST=127.0.0.1

REDIS_IMAGE=redis:7.2.4
REDIS_CONTAINER_NAME=lab-management-redis
REDIS_PORT=6379

APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_REMINDER_DAYS=30
APP_JWT_SECRET=请替换为足够长的随机密钥
APP_JWT_EXPIRE_MINUTES=720
AUTH_HEADER_PREFIX=Bearer
APP_INIT_ADMIN_ENABLED=true
APP_INIT_ADMIN_USERNAME=admin
APP_INIT_ADMIN_PASSWORD=请在首次启动前修改密码
APP_INIT_ADMIN_REAL_NAME=系统管理员
APP_INIT_ADMIN_USER_NO=admin001
APP_SAMPLE_DATA_ENABLED=true
APP_SAMPLE_DATA_RESOURCE=classpath:sample-data/demo-data.json
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.nologging.NoLoggingImpl

OPENAPI_TITLE=实验室设备与耗材管理系统接口文档
OPENAPI_VERSION=1.0.0
OPENAPI_DESCRIPTION=实验室设备与耗材管理系统后端接口说明
OPENAPI_CONTACT_NAME=实验室平台维护组
OPENAPI_CONTACT_EMAIL=lab-admin@university.edu
OPENAPI_EXTERNAL_DOCS_DESCRIPTION=项目说明文档
OPENAPI_EXTERNAL_DOCS_URL=http://127.0.0.1:8080/swagger-ui.html

APP_JAVA_HOME=/path/to/jdk-17
